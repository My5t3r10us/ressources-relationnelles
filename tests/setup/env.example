# Copy values into your shell env or a .env.test file
# IMPORTANT: must point to a database SEPARATE from your dev database.
DATABASE_URL_TEST=postgres://postgres:postgres@localhost:5432/resources_test

# S3 dummies (the test harness mocks S3, so any non-empty value works)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_BUCKET=resources-test
AWS_PUBLIC_URL=https://test.example.com
