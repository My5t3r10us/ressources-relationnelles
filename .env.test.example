# =============================================================================
# .env.test.example
# -----------------------------------------------------------------------------
# Copiez ce fichier vers .env.test (ou exportez les variables dans votre shell)
# avant de lancer la suite de tests.
#
#   cp .env.test.example .env.test
#
# IMPORTANT : la base de données de test DOIT être SÉPARÉE de votre base
# de développement. Le helper tests/setup/db.ts fait un TRUNCATE de toutes
# les tables entre chaque test — si vous pointez vers votre base dev,
# elle sera vidée.
#
# Setup initial (une seule fois) :
#   createdb resources_test
#   export DATABASE_URL_TEST=postgres://postgres:postgres@localhost:5432/resources_test
#   npm run db:test:push     # applique le schéma Drizzle sur la base de test
# =============================================================================


# -----------------------------------------------------------------------------
# Base de données de test (REQUIS pour tests/api/** et Playwright)
# -----------------------------------------------------------------------------
# URL Postgres dédiée aux tests. NE PAS réutiliser la base de dev.
# Le setup Vitest écrase DATABASE_URL avec cette valeur quand elle est définie.
DATABASE_URL_TEST=postgres://postgres:postgres@localhost:5432/resources_test

# Fallback pour les outils qui ignorent DATABASE_URL_TEST (drizzle-kit, scripts).
# Doit pointer vers la MÊME base que DATABASE_URL_TEST pendant les tests.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/resources_test


# -----------------------------------------------------------------------------
# Better Auth
# -----------------------------------------------------------------------------
# URL publique sur laquelle better-auth crée ses callbacks. Pour les tests
# unitaires/API on n'a pas de vrai serveur, localhost:3000 suffit pour
# silencer les warnings.
BETTER_AUTH_URL=http://localhost:3000

# Secret de signature des sessions. En test, n'importe quelle chaîne >= 32 chars.
# NE JAMAIS réutiliser ce secret en production.
BETTER_AUTH_SECRET=test-secret-do-not-use-in-production-please-32chars


# -----------------------------------------------------------------------------
# Auth client (utilisé côté navigateur/composants React testés via jsdom)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# S3 / Tigris (mocké par les tests, valeurs factices acceptables)
# -----------------------------------------------------------------------------
# Le harness Vitest mock @/lib/s3 dans les tests qui en ont besoin, donc
# ces valeurs ne sortent jamais. Elles existent uniquement pour que
# l'instanciation du client S3 ne plante pas à l'import.
AWS_REGION=auto
AWS_ENDPOINT_URL_S3=https://t3.storage.dev
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_BUCKET=resources-test
AWS_PUBLIC_URL=https://test.example.com


# -----------------------------------------------------------------------------
# Playwright (tests E2E)
# -----------------------------------------------------------------------------
# Port sur lequel Playwright lance `next dev`. Doit être libre.
PORT=3000

# URL ciblée par les specs. Surchargez si vous testez contre un serveur
# déjà lancé en CI (combiné avec PLAYWRIGHT_NO_SERVER=1).
BASE_URL=http://localhost:3000

# Décommentez en CI si un service Postgres + Next.js tourne déjà à part
# et que vous ne voulez pas que Playwright relance `next dev`.
# PLAYWRIGHT_NO_SERVER=1


# -----------------------------------------------------------------------------
# Mobile (Maestro + Expo)
# -----------------------------------------------------------------------------
# URL de l'API que l'app mobile attaque. Pour tester contre l'environnement
# de test, pointez vers votre Next.js de test (par défaut localhost:3000).
# Sur émulateur Android, utilisez 10.0.2.2 au lieu de localhost.
EXPO_PUBLIC_API_URL=http://localhost:3000
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3000   # Android emulator


# -----------------------------------------------------------------------------
# Comptes seed E2E (référencés par tests/e2e/global.setup.ts et les flows Maestro)
# -----------------------------------------------------------------------------
# Ces comptes sont créés automatiquement par le global setup Playwright.
# Si vous changez ces valeurs, mettez à jour aussi :
#   - tests/e2e/helpers/auth.ts        (E2E_ADMIN, E2E_CITIZEN)
#   - mobile/.maestro/flows/auth/_login-helper.yaml
#   - mobile/.maestro/flows/admin/admin-tab.yaml
E2E_ADMIN_EMAIL=admin-e2e@test.local
E2E_ADMIN_PASSWORD=Password123!
E2E_CITIZEN_EMAIL=citizen-e2e@test.local
E2E_CITIZEN_PASSWORD=Password123!


# -----------------------------------------------------------------------------
# Divers
# -----------------------------------------------------------------------------
# Force NODE_ENV à "test" pour que les libs qui détectent l'environnement
# (drizzle, better-auth, next) se mettent en mode dev/test.
NODE_ENV=test
